{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["bot_token"],
  "properties": {
    "bot_token": {
      "type": "string",
      "description": "Telegram Bot Token, 从 @BotFather 获取"
    },
    "allowed_users": {
      "type": "array",
      "items": { "type": "string" },
      "description": "允许的 Telegram user ID 列表，空数组表示允许所有人",
      "default": []
    }
  }
}
